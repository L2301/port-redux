{
  "name": "port",
  "productName": "Port",
  "version": "2.0.0",
  "description": "A ship runner and manager for Urbit OS — compatible with Vere v4.x",
  "repository": {
    "type": "git",
    "url": "https://github.com/L2301/port-redux.git"
  },
  "keywords": ["urbit", "vere", "ship-manager"],
  "author": {
    "name": "Urbit Foundation",
    "email": "dev@urbit.org"
  },
  "license": "MIT",
  "main": ".webpack/main",
  "config": {
    "forge": "./forge.config.js"
  },
  "scripts": {
    "start": "electron-forge start -- --no-sandbox",
    "dev:reset": "rm -rf .webpack && rm -rf node_modules && npm install",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:all": "npm run make:mac && npm run make:mac-arm && npm run make:linux && npm run make:win",
    "make:mac": "electron-forge make --platform darwin --arch x64",
    "make:mac-arm": "electron-forge make --platform darwin --arch arm64",
    "make:linux": "electron-forge make --platform linux --arch x64",
    "make:win": "electron-forge make --platform win32 --arch x64",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts .",
    "vere": "./get-vere.sh",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-webpack": "^7.6.0",
    "@electron-forge/publisher-github": "^7.6.0",
    "@types/async": "^3.2.24",
    "@types/lodash.debounce": "^4.0.9",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "autoprefixer": "^10.4.20",
    "css-loader": "^7.1.0",
    "cssnano": "^7.0.0",
    "dotenv": "^16.4.0",
    "electron": "^33.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.31.0",
    "fork-ts-checker-webpack-plugin": "^9.0.0",
    "fs-extra": "^11.2.0",
    "mini-css-extract-plugin": "^2.9.0",
    "node-loader": "^2.1.0",
    "postcss": "^8.4.49",
    "postcss-import": "^16.1.0",
    "postcss-loader": "^8.1.0",
    "postcss-preset-env": "^10.1.0",
    "string-replace-loader": "^3.1.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.17",
    "ts-loader": "^9.5.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@types/adm-zip": "^0.5.5",
    "@types/uuid": "^10.0.0",
    "adm-zip": "^0.5.16",
    "app-root-dir": "^1.0.2",
    "async": "^3.2.6",
    "axios": "^1.7.0",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "electron-context-menu": "^4.0.4",
    "electron-squirrel-startup": "^1.0.1",
    "electron-window-state": "^5.0.3",
    "find-process": "^1.4.7",
    "lodash.debounce": "^4.0.8",
    "nedb": "^1.8.0",
    "nedb-async": "^0.1.6",
    "node-ipc": "^9.2.1",
    "node-pty": "^1.0.0",
    "patch-package": "^8.0.0",
    "query-string": "^9.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-error-boundary": "^5.0.0",
    "react-hook-form": "^7.54.0",
    "react-query": "^3.39.3",
    "react-router-dom": "^5.3.4",
    "update-electron-app": "^3.0.0",
    "use-resize-observer": "^9.1.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "uuid": "^11.0.0",
    "zustand": "^4.5.0"
  }
}
